# Open Terminal Isolated Environment Configuration
# 
# SECURITY: This file contains sensitive credentials.
# DO NOT commit .env to version control.
# 
# Copy this file to .env and fill in with real values:
#   cp infra/.env.example infra/.env
#
# To generate OPEN_TERMINAL_API_KEY:
#   openssl rand -hex 32

# Required: API key for Open Terminal authentication
# Generate with: openssl rand -hex 32
OPEN_TERMINAL_API_KEY=your-generated-random-hex-key-here

# Optional: API key sent by little-coder to the host's llama-ingress-proxy.
# Most local llama.cpp / llama-swap setups ignore this, so the default 'noop'
# is fine. Set it only if your proxy enforces a bearer token.
LLAMACPP_API_KEY=noop

# Optional: GitHub token for repository access (inject at runtime if needed)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MODEL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
